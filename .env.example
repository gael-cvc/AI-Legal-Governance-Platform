# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── RAG Config ─────────────────────────────────────────────────────────────────
MIN_SCORE=0.35
DEFAULT_K=5

# ── Runtime ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEVICE=cpu
